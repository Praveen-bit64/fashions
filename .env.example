# ─── AI provider selection ────────────────────────────────────────────
# Which provider /api/ai-preview should use. Defaults to "gemini".
#   gemini  → Google Gemini 2.5 Flash Image (free tier available)
#   openai  → OpenAI gpt-image-1 (requires $5 prepay + verified org)
AI_PROVIDER=gemini

# ─── Google Gemini (free tier) ────────────────────────────────────────
# Get a free key at https://aistudio.google.com/apikey — no card required
GEMINI_API_KEY=
# Optional model override
# GEMINI_MODEL=gemini-2.5-flash-image-preview

# ─── OpenAI (paid) ────────────────────────────────────────────────────
# Only required if AI_PROVIDER=openai
OPENAI_API_KEY=

# ─── Cloudinary (image storage, free tier) ────────────────────────────
# https://console.cloudinary.com/settings/api-keys
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Postgres (quota / rate limiting) ─────────────────────────────────
# Same credentials as the Express server in /server/.env
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=fashion_26

# ─── Optional quota overrides ─────────────────────────────────────────
ANON_LIFETIME_QUOTA=2
USER_DAILY_QUOTA=10
