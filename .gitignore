# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# ─── Dependencies ──────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ─── Build output ──────────────────────────────────────────────
/.next/
/out/
/build/
/dist/
*.tsbuildinfo
next-env.d.ts

# ─── Environment & secrets ─────────────────────────────────────
.env
.env.*
!.env.example

# ─── Editor / IDE ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ─── OS junk ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
*.pem

# ─── Logs ──────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-debug.log*

# ─── Test & coverage ───────────────────────────────────────────
/coverage

# ─── Local tooling state ───────────────────────────────────────
.claude/
.cursor/
.aider*

# ─── Hosting / platform ────────────────────────────────────────
.vercel
.netlify

# ─── Prisma local artifacts ────────────────────────────────────
prisma/migrations/dev.db*
prisma/*.db
prisma/*.db-journal

# ─── Local uploads / temp ──────────────────────────────────────
public/uploads/
tmp/
temp/
